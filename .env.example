BASE_URL=https://your-site-url.com
TEST_USERNAME=your_test_username
TEST_PASSWORD=your_test_password

# ─── 회원가입 이메일 인증 자동화 (T421 / T758) ───────────────────────────────
# 회원가입 시 발송되는 인증 메일을 IMAP으로 읽어 JWT 토큰을 자동 추출합니다.
# 테스트 이메일: EMAIL_IMAP_USER+<timestamp>@domain 형식으로 매 실행마다 고유 주소 사용
# (Gmail plus addressing 권장 — 모두 동일 받은편지함에 수신됨)

EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_SECURE=true
EMAIL_IMAP_USER=your_test_email@gmail.com
EMAIL_IMAP_PASS=your_app_password

# 최대 대기 시간(ms). 기본 60000 (60초). 느린 환경은 90000 권장
EMAIL_MAX_WAIT_MS=90000

# ── 이메일 제공사별 IMAP 설정 가이드 ────────────────────────────────────────
# Gmail:  imap.gmail.com:993 — Google 계정 > 보안 > 앱 비밀번호 발급 후 사용
# Naver:  imap.naver.com:993 — 네이버 메일 > 환경설정 > POP3/IMAP 사용 설정 후 앱 비밀번호
# Daum:   imap.daum.net:993
# 사내메일: IT 담당자에게 IMAP 서버 주소 확인
